{% comment %} Section: recommendations carousel{% endcomment %}

<script src="{{ 'recommendations-carousel.js' | asset_url }}" defer></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }


  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="recommendations-carousel section-{{ section.id }} section-{{ section.id }}-padding tw:dark:bg-black">
  <div class="page-width">
    <recommendations-carousel
      data-url="{{ routes.product_recommendations_url }}?limit={{ section.settings.products_to_show }}"
      data-section-id="{{ section.id }}"
      data-product-id="{{ product.id }}"
    >
      {% if recommendations.performed and recommendations.products_count > 0 %}
        <h2 class="tw:text-2xl! tw:md:text-3xl! tw:font-normal! tw:text-center tw:mb-8">
          {{- section.settings.heading -}}
        </h2>
      {% endif %}
      <div class="swiper recommendations-carousel__swiper tw:h-fit">
        <div class="swiper-wrapper">
          {% for recommended_product in recommendations.products %}
            <div class="swiper-slide">
              {%- render 'custom-product-card', product: recommended_product, show_price: true, show_rating: false -%}
            </div>
          {% endfor %}
        </div>
        <div class="swiper-button-next tw:w-10 tw:h-10 tw:aria-disabled:!opacity-0">
            {{- 'slider-arrow.svg' | inline_asset_content -}}
          </div>
          <div class="swiper-button-prev tw:transform tw:rotate-180 tw:w-10 tw:h-10 tw:aria-disabled:!opacity-0">
            {{- 'slider-arrow.svg' | inline_asset_content -}}
          </div>
      </div>
    </recommendations-carousel>
  </div>
</section>

{% schema %}
{
  "name": "Recommendations Carousel",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "t:sections.recommendations-carousel.name"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "t:sections.recommendations-carousel.settings.products_to_show.label",
      "default": 10,
      "min": 1,
      "max": 10,
      "step": 1
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.recommendations-carousel.settings.padding.padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.recommendations-carousel.settings.padding.padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "t:sections.recommendations-carousel.presets.name"
    }
  ],
  "enabled_on": {
    "templates": ["product"]
  }
}
{% endschema %}

<script></script>
