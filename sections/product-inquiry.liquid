{{ 'product-inquiry.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-inquiry.js' | asset_url }}" defer></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section
  class="product-inquiry-section section-{{ section.id }} section-{{ section.id }}-padding"
  id="product-inquiry-section-{{ section.id }}"
  aria-labelledby="product-inquiry-title"
>
    {% if product %}
  <div class="container">
    {% form 'product', product, class: 'product-inquiry__form', data-type: 'add-to-cart-form' %}
      <div class="form-container" aria-busy="false">
        {% if form.posted_successfully? %}
          <div role="status" aria-live="polite" class="form-success">
            {{- 'product-form.inquiry.success' | t -}}
          </div>
        {% endif %}

        {% if form.errors %}
          <div class="form-errors" role="alert" aria-live="assertive">
            <h3>{{ 'product-form.inquiry.error' | t }}</h3>
            {{- form.errors | default_errors -}}
          </div>
        {% endif %}

        {% unless product.has_only_default_variant %}
          <div class="form-field">
            <label for="product-variant">
              {{ 'product-form.inquiry.variant' | t }}
            </label>
            <select name="id" id="product-variant" required>
              {% for variant in product.variants %}
                <option
                  value="{{ variant.id }}"
                  data-stock="
                      {% if variant.inventory_management != blank %}
                          {% if variant.inventory_quantity > 1 %}
                              {{ 'product-form.inquiry.in_stock' | t }}
                              {{ variant.inventory_quantity }}
                              {{ 'product-form.inquiry.units' | t }}
                          {% elsif variant.inventory_quantity > 0 %}
                              {{ 'product-form.inquiry.in_stock' | t }}
                              {{ variant.inventory_quantity }}
                              {{ 'product-form.inquiry.unit' | t }}
                          {% else %}
                              {{ 'product-form.inquiry.not_available' | t }}
                          {% endif %}
                      {% else %}
                          {% if variant.available -%}
                          {{- 'product-form.inquiry.in_stock' | t -}}
                          {%- else -%}
                          {{- 'product-form.inquiry.not_available' | t -}}
                          {%- endif %}
                      {% endif %}"
                  {% if variant == product.selected_or_first_available_variant %}
                    selected
                  {% endif %}
                  {% unless variant.available %}
                    disabled
                  {% endunless %}
                >
                  {{- variant.title -}}
                  {% unless variant.available %} - {{ 'product-form.inquiry.sold_out' | t }}{% endunless %}
                </option>
              {% endfor %}
            </select>
          </div>
        {% else %}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        {% endunless %}

        <div class="form-field">
          <label for="product-quantity">{{ 'product-form.inquiry.quantity' | t }}</label>
          <input
            type="number"
            name="quantity"
            id="product-quantity"
            value="1"
            min="1"
            required
            {% if product.selected_or_first_available_variant.inventory_management != blank %}
              max="{{ product.selected_or_first_available_variant.inventory_quantity }}"
            {% else %}
              max="100"
            {% endif %}
            {% if form.errors contains 'quantity' %}
              aria-invalid="true"
              aria-describedby="quantity-error"
            {% endif %}
          >
          {% if form.errors contains 'quantity' %}
            <div id="quantity-error" class="field-error">
              {{ form.errors.translated_fields.quantity | capitalize }}
              {{ form.errors.messages.quantity }}
            </div>
          {% endif %}
        </div>

        <div class="stock" id="product-stock">
          {% if product.selected_or_first_available_variant.inventory_management != blank %}
            {% if product.selected_or_first_available_variant.inventory_quantity > 1 %}
              <span>
                {{ 'product-form.inquiry.in_stock' | t }}
                {{ product.selected_or_first_available_variant.inventory_quantity }}
                {{ 'product-form.inquiry.units' | t }}
              </span>
            {% elsif product.selected_or_first_available_variant.inventory_quantity > 0 %}
              <span>
                {{ 'product-form.inquiry.in_stock' | t }}
                {{ product.selected_or_first_available_variant.inventory_quantity }}
                {{ 'product-form.inquiry.unit' | t }}
              </span>
            {% else %}
              <span>
                {{ 'product-form.inquiry.not_available' | t }}
              </span>
            {% endif %}
          {% else %}
            {% if product.selected_or_first_available_variant.available -%}
              {{- 'product-form.inquiry.in_stock' | t -}}
            {%- else -%}
              {{- 'product-form.inquiry.not_available' | t -}}
            {%- endif %}
          {% endif %}
        </div>

        <div class="form-field">
          <label for="inquiry-reason">{{ 'product-form.inquiry.reason' | t }}</label>
          <input
            type="text"
            name="properties[Reason]"
            id="inquiry-reason"
            placeholder="{{ 'product-form.inquiry.reason_placeholder' | t }}"
          >
        </div>

        <div class="form-field">
          <div class="form-field-label">{{ 'product-form.inquiry.preferred_contact' | t }}</div>
          <div class="radio-group">
            <label class="radio-option">
              <input type="radio" name="properties[Preferred contact]" value="email" checked>
              <span class="radio-label">{{ 'product-form.inquiry.contact_email' | t }}</span>
            </label>
            <label class="radio-option">
              <input type="radio" name="properties[Preferred contact]" value="phone">
              <span class="radio-label">{{ 'product-form.inquiry.contact_phone' | t }}</span>
            </label>
            <label class="radio-option">
              <input type="radio" name="properties[Preferred contact]" value="no_contact">
              <span class="radio-label">{{ 'product-form.inquiry.contact_none' | t }}</span>
            </label>
          </div>
        </div>

        <div class="form-actions">
          <button
            type="submit"
            class="btn btn-primary"
            {% unless product.selected_or_first_available_variant.available %}
              disabled
            {% endunless %}
          >
            {% if product.selected_or_first_available_variant.available %}
              {{ 'product-form.inquiry.submit' | t }}
            {% else %}
              {{ 'product-form.inquiry.sold_out' | t }}
            {% endif %}
          </button>

          {% unless product.selected_or_first_available_variant.available %}
            <div role="status" aria-live="polite" class="availability-message">
              {{ 'product-form.inquiry.unavailable_message' | t }}
            </div>
          {% endunless %}
        </div>
      </div>
    {% endform %}
  </div>
  {% else %}
    <h2>{{- 'product-form.inquiry.no_product' | t -}}</h2>
  {% endif %}
</section>

{% schema %}
{
  "name": "Product inquiry form",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "t:sections.product-inquiry.name"
    },
     {
      "type": "range",
      "id": "padding_top",
      "label": "t:product-inquiry.settings.padding.padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:product-inquiry.settings.padding.padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Product inquiry"
    }
  ]
}
{% endschema %}

