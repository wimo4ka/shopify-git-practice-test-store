{% comment %}
  Universal Product Banner Snippet
  Usage:
  {% render 'banner-product', product: product %}
{% endcomment %}

{{ 'banner-product.css' | asset_url | stylesheet_tag }}
{{ 'main.css' | asset_url | stylesheet_tag }}
{{ 'bundle.js' | asset_url | script_tag }}

<div class="banner-product">
  {% comment %} Product image {% endcomment %}
  <div class="product-image">
    {% if product.has_only_default_variant %}
      {% if product.featured_image != blank %}
        <img
          id="main-image"
          src="{{ product.featured_image | image_url: width: 600  }}"
          alt="{{ product.title }} "
          loading="lazy"
        >
      {% else %}
        <img
          id="main-image"
          src="{{ 'no-image.svg' | asset_url }}"
          alt="No image available"
          loading="lazy"
        >
      {% endif %}
    {% else %}
      {% if product.selected_or_first_available_variant.featured_image != blank %}
        <img id="main-image" src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title }}">

      {% elsif product.featured_image != blank %}
        <img
          id="main-image"
          src="{{ product.featured_image | image_url: width: 600 }}"
          alt="{{ product.title }}"
          loading="lazy"
        >
      {% else %}
        <img
          id="main-image"
          src="{{ 'no-image.svg' | asset_url }}"
          alt="No image available"
        >
      {% endif %}
    {% endif %}
    <div class="badge">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M10 13.0721L7.11574 14.6666L7.66671 11.2895L5.33337 8.89805L8.55789 8.40571L10 5.33325L11.4422 8.40571L14.6667 8.89805L12.3334 11.2895L12.8843 14.6666L10 13.0721Z" fill="#111111" stroke="#111111" stroke-width="1.33333" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span class="badge-text">{{ 'product.banner.badge_text' | t }}</span>
    </div>
  </div>
  {% comment %} Product form {% endcomment %}
  <div>
    {% if product.title != blank %}
      <h1>{{ product.title }}</h1>
    {% endif %}

    {% capture product_price %}
      {{ product.selected_or_first_available_variant.price | money }}
    {% endcapture %}

    <div class="price product-price" id="product-price">
      {{ product_price }}
    </div>

    <div class="stock" id="product-stock">
      {% if product.selected_or_first_available_variant.inventory_management != blank %}
        {% if variant.inventory_quantity > 0 %}
          {{ 'product.banner.in_stock' | t }}
        {% else %}
          {{ 'product.banner.not_available' | t }}
        {% endif %}
      {% else %}
        {% if product.selected_or_first_available_variant.available -%}
          {{- 'product.banner.in_stock' | t -}}
        {%- else -%}
          {{- 'product.banner.not_available' | t -}}
        {%- endif %}
      {% endif %}
    </div>

    {% form 'product', product %}
      {% comment %} Assign of product options {% endcomment %}
      {% for option in product.options_with_values %}
        {% assign option_name = option.name | downcase %}
        {% case option_name %}
          {% when 'color', 'colour', 'цвет' %}
            {% assign color_option = option %}
          {% when 'shoe size', 'размер обуви' %}
            {% assign size_option = option %}
        {% endcase %}
      {% endfor %}

      {% comment %} Chose color {% endcomment %}
      {% if color_option != blank %}
        <label class="option-label">{{ 'product.banner.color_label' | t | default: 'Size' }}</label>
        <div class="color-thumbs">
          {% for value in color_option.values limit: 3 %}
            {% assign variant = product.variants | where: 'option1', value | first %}
            {% if variant != blank %}
              {% assign color_hex = '#cccccc' %}
              {% case value %}
                {% when 'White' -%}
                  {%- assign color_hex = '#ffffff' %}
                {% when 'Pink' -%}
                  {%- assign color_hex = '#f81aaeff' %}
                {% when 'Black' -%}
                  {%- assign color_hex = '#000000' %}
              {% endcase %}
              <button
                type="button"
                class="color-thumb {% if forloop.first %}active{% endif %}"
                data-value="{{ value }}"
                data-variant-id="{{ variant.id }}"
                data-image="{{ variant.featured_image | image_url: width: 600 }}"
                data-price="{{ variant.price | money }}"
                data-qty="{% if variant.inventory_management %}{{ variant.inventory_quantity }}{% else %}{% if variant.available %}{{ 'product.banner.in_stock' | t }}{% else %}{{ 'product.banner.not_available' | t }}{% endif %}{% endif %}"
                data-available="{{ variant.available }}"
              >
                {% if variant.featured_image != blank %}
                  <img src="{{ variant.featured_image | image_url: width: 100 }}" alt="{{ value }}">
                {% else %}
                  <span style="background-color: {{ color_hex }};">{{ value }}</span>
                {% endif %}
              </button>
            {% endif %}
          {% endfor %}
        </div>
        <input
          type="hidden"
          name="options[{{ color_option.name }}]"
          id="selected-color"
          value="{{ color_option.values.first }}"
        >
      {% endif %}

      {% comment %} Chose size {% endcomment %}
      {% if size_option != blank %}
        <label class="option-label">{{ 'product.banner.size_label' | t }}</label>
        <div class="size-buttons">
          {% for value in size_option.values %}
            <button type="button" class="size-btn {% if forloop.first %}active{% endif %}" data-value="{{ value }}">
              {{ 'product.banner.size_text' | t }}
              {{ value }}
            </button>
          {% endfor %}
        </div>
        <input
          type="hidden"
          name="options[{{ size_option.name }}]"
          id="selected-size"
          value="{{ size_option.values.first }}"
        >
      {% endif %}

      {% comment %} Hidden select {% endcomment %}
      <select name="id" id="variant-select" class="hidden">
        {% for variant in product.variants %}
          <option
            value="{{ variant.id }}"
            data-color="{{ variant.option1 }}"
            data-size="{{ variant.option2 }}"
            data-price="{{ variant.price | money }}"
            data-image="{% if variant.featured_image != blank %}{{ variant.featured_image | image_url: width: 600}}{% else %}{{ 'no-image.svg' | asset_url }}{% endif %}"
            data-stock="{% if variant.inventory_management != blank %}{% if variant.inventory_quantity > 0 %}{{ 'product.banner.in_stock' | t }}{%else%}{{ 'product.banner.not_available' | t }}{% endif %}{% else %}{% if variant.available %}{{ 'product.banner.in_stock' | t }}{% else %}{{ 'product.banner.not_available' | t }}{% endif %}{% endif %}"
            data-available="{{ variant.available }}"
            {% if variant == product.selected_or_first_available_variant %}
              selected
            {% endif %}
          >
            {{ variant.title }}
          </option>
        {% endfor %}
      </select>

      {% if product.description != blank %}
        <div class="product-description">
          {{ product.description }}
        </div>
      {% endif %}

      <button type="submit" class="add-to-cart">
        {{ 'product.banner.add_to_cart' | t }}
      </button>
    {% endform %}
  </div>
</div>

{% assign images = product.images %}

<div class="wrapper">
  <div style="--swiper-navigation-color: #fff; --swiper-pagination-color: #fff" class="swiper mySwiper2">
    <div class="swiper-wrapper">
      {% for image in images %}
        <div class="swiper-slide">
          <img src="{{ image | image_url: width: 536 }}" alt="{{ product.title}}" width="536px" height="536px" data-color="{{ image.alt }}">
        </div>
      {% endfor %}
    </div>
  </div>

  <div thumbsSlider class="swiper mySwiper">
    <div class="swiper-wrapper">
      {% for image in images %}
          <div class="swiper-slide">
            <img src="{{ image | image_url: width: 150 }}" alt="{{ product.title }}" data-color="{{ image.alt }}" width="88px" height="88px">
          </div>
      {% endfor %}
    </div>
  </div>
</div>

{{ 'banner-product.js' | asset_url | script_tag }}

<script>
  console.log({{ product | json }})
</script>