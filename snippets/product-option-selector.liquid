{%- comment -%}
  snippets/product-option-selector.liquid
  Universal product option selector
  Usage:
    {%- render 'product-option-selector', option: color_option, option_type: 'color', limit: 3 -%}
{%- endcomment -%}

{% if option != blank %}
  <label class="option-label mb-4 text-brand-gray text-black font-medium dark:text-white" for="selected-{{ option_type }}">
    {% case option_type %}
      {% when 'color' %}
        {{ 'product.banner.color_label' | t | default: 'Color' }}
      {% when 'size' %}
        {{ 'product.banner.size_label' | t | default: 'Size' }}
      {% else %}
        {{ option.name }}
    {% endcase %}
  </label>

  <div
    {% if option_type == 'color' %}
      class="{{ option_type }}-options grid grid-cols-3 gap-3"
    {% else %}
      class="{{ option_type }}-options grid grid-cols-3 gap-3"
    {% endif %}
  >
    {% assign option_values = option.values %}

    {% if limit %}
      {% assign option_values = option_values | slice: 0, limit %}
    {% endif %}

    {%- for value in option_values -%}
      {% case option.position %}
        {% when 1 %}
          {% assign variant = product.variants | where: 'option1', value | first %}
        {% when 2 %}
          {% assign variant = product.variants | where: 'option2', value | first %}
        {% when 3 %}
          {% assign variant = product.variants | where: 'option3', value | first %}
        {% else %}
          {% assign variant = product.variants | where: 'option1', value | first %}
      {% endcase %}

      {% if variant != blank %}
        {% assign image = variant.featured_image %}
        {% assign available = variant.available %}
        {% assign stock = variant.inventory_quantity %}

        {% if option_type == 'color' %}
          {% assign color_hex = '#cccccc' %}
          {% case value %}
            {% when 'White' -%}
              {%- assign color_hex = '#ffffff' %}
            {% when 'Pink' -%}
              {%- assign color_hex = '#f81aaeff' %}
            {% when 'Black' -%}
              {%- assign color_hex = '#000000' %}
          {% endcase %}

          <button
            type="button"
            class="color-thumb {% if forloop.first %}active border-gray-900 dark:border-gray-300{% endif %} aspect-square w-28 h-28 flex items-center justify-center border border-gray-300 rounded-md overflow-hidden"
            data-value="{{ value }}"
            data-variant-id="{{ variant.id }}"
            data-image="{{ image | image_url: width: 600 }}"
            data-price="{{ variant.price | money }}"
            data-stock="{{ stock }}"
            data-available="{{ available }}"
          >
            {% if image != blank %}
              {{
                image
                | image_url: width: 100
                | image_tag: alt: value, loading: 'lazy', class: 'w-full object-cover aspect-square'
              }}
            {% else %}
              <span style="background-color: {{ color_hex }};"></span>
            {% endif %}
          </button>
        {% else %}
          <button
            type="button"
            class="size-btn {% if forloop.first %}active bg-black text-white dark:bg-white dark:!text-black{% endif %} w-1/4 py-3 px-4 border border-gray-300 rounded-md text-center font-medium text-brand-gray hover:border-black focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-black text-brand-gray text-black font-medium text-2xl dark:border-white dark:text-white dark:hover:border-gray-300 dark:focus:ring-white"
            data-value="{{ value }}"
            data-stock="{{ stock }}"
            data-available="{{ available }}"
          >
            {{ 'product.banner.size_text' | t }}
            {{ value }}
          </button>
        {% endif %}
      {% endif %}
    {%- endfor -%}
  </div>

  <input
    type="hidden"
    name="options[{{ option.name }}]"
    id="selected-{{ option_type }}"
    value="{{ option.values.first }}"
  >
{% endif %}
