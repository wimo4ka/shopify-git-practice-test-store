{%- comment -%}
  snippets/product-option-selector.liquid
  Universal product option selector
  Usage:
    {%- render 'product-option-selector', option: color_option, option_type: 'color', limit: 3 -%}
{%- endcomment -%}

{% if option != blank %}
  <label 
    class="option-label tw:mb-4 tw:text-brand-gray tw:text-black tw:font-medium tw:dark:text-white"
    id="label-{{ option_type }}"
  >
    {% case option_type %}
      {% when 'color' %}
        {{ 'product.banner.color_label' | t | default: 'Color' }}
      {% when 'size' %}
        {{ 'product.banner.size_label' | t | default: 'Size' }}
      {% else %}
        {{ option.name }}
    {% endcase %}
  </label>

  <div
    role="radiogroup"
    aria-labelledby="label-{{ option_type }}"
    {% if option_type == 'color' %}
      class="{{ option_type }}-options tw:flex tw:gap-3 tw:mb-4"
    {% else %}
      class="{{ option_type }}-options tw:grid tw:grid-cols-3 tw:gap-3 tw:mb-4"
    {% endif %}
  >
    {% assign option_values = option.values %}
    {% if limit %}
      {% assign option_values = option_values | slice: 0, limit %}
    {% endif %}

    {% for value in option_values %}
      {% case option.position %}
        {% when 1 %}
          {% assign variant = product.variants | where: 'option1', value | first %}
        {% when 2 %}
          {% assign variant = product.variants | where: 'option2', value | first %}
        {% when 3 %}
          {% assign variant = product.variants | where: 'option3', value | first %}
        {% else %}
          {% assign variant = product.variants | where: 'option1', value | first %}
      {% endcase %}

      {% if variant != blank %}
        {% assign image = variant.featured_image %}
        {% assign available = variant.available %}
        {% assign stock = variant.inventory_quantity %}

        {% assign is_active = forloop.first %}

        {% if option_type == 'color' %}
          {%- assign color_hex = '#cccccc' -%}
          {% case value %}
            {% when 'White' %}
              {% assign color_hex = '#ffffff' %}
            {% when 'Pink' %}
              {% assign color_hex = '#f81aaeff' %}
            {% when 'Black' %}
              {% assign color_hex = '#000000' %}
          {% endcase %}

          <button
            role="radio"
            aria-checked="{{ is_active }}"
            aria-label="Color {{ value }}"
            tabindex="{% if is_active %}0{% else %}-1{% endif %}"
            type="button"
            class="color-thumb {% if is_active %}active tw:border-gray-900 tw:dark:border-gray-300{% endif %} tw:aspect-square tw:w-28 tw:h-28 tw:flex tw:items-center tw:justify-center tw:border tw:border-gray-300 tw:rounded-md tw:overflow-hidden"
            data-value="{{ value }}"
            data-variant-id="{{ variant.id }}"
            data-image="{{ image | image_url: width: 600 }}"
            data-price="{{ variant.price | money }}"
            data-stock="{{ stock }}"
            data-available="{{ available }}"
          >
            {% if image != blank %}
              {{
                image
                | image_url: width: 100
                | image_tag: alt: value, class: 'tw:w-full tw:object-cover tw:aspect-square'
              }}
            {% else %}
              <span class="tw:w-full tw:h-full" style="background-color: {{ color_hex }};"></span>
            {% endif %}
          </button>

        {% else %}
          <button
            role="radio"
            aria-checked="{{ is_active }}"
            aria-label="Size {{ value }}"
            tabindex="{% if is_active %}0{% else %}-1{% endif %}"
            type="button"
            class="size-btn {% if is_active %}active tw:bg-black tw:text-white tw:dark:bg-white tw:dark:!text-black{% endif %} tw:w-full tw:py-3 tw:px-4 tw:border border-gray-300 tw:rounded-md tw:text-center tw:font-medium tw:text-brand-gray tw:hover:border-black tw:focus:outline-none tw:focus:ring-2 tw:focus:ring-offset-2 tw:focus:ring-black tw:text-base tw:dark:border-white tw:dark:text-white tw:dark:hover:border-gray-300 tw:dark:focus:ring-white"
            data-value="{{ value }}"
            data-stock="{{ stock }}"
            data-available="{{ available }}"
          >
            {{ 'product.banner.size_text' | t }}
            {{ value }}
          </button>
        {% endif %}
      {% endif %}
    {%- endfor -%}
  </div>

  <input
    type="hidden"
    name="options[{{ option.name }}]"
    id="selected-{{ option_type }}"
    value="{{ option.values.first }}"
  >
{% endif %}

